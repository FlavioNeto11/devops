{
  "name": "novait-portal",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "description": "Portal NovaIT — landing pública na raiz (/) da plataforma DevOps. Estático (nginx) com enriquecimento progressivo via API read-only do Console.",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test",
    "test:watch": "node --test --watch",
    "lint": "eslint .",
    "format": "prettier --write \"assets/**/*.{js,css}\" \"test/**/*.mjs\" \"*.json\" \"eslint.config.js\"",
    "format:check": "prettier --check \"assets/**/*.{js,css}\" \"test/**/*.mjs\" \"*.json\" \"eslint.config.js\"",
    "validate": "npm run format:check && npm run lint && npm test"
  },
  "keywords": [
    "novait",
    "portal",
    "devops",
    "static"
  ],
  "author": "NovaIT",
  "license": "MIT",
  "devDependencies": {
    "@eslint/js": "^9.13.0",
    "eslint": "^9.13.0",
    "globals": "^15.11.0",
    "prettier": "^3.3.3"
  }
}
