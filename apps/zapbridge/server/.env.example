# ZapBridge backend - exemplo de variáveis de ambiente
# Copie para `.env` e ajuste os valores.

PORT=3000

# Segredo do JWT (troque por um valor forte e único)
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=30d

# Banco SQLite (Prisma). Para PostgreSQL, troque o provider em prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# Origem permitida no CORS (use * apenas em desenvolvimento)
CORS_ORIGIN=*

# Pastas de armazenamento local
AUTH_DIR=storage/auth
MEDIA_DIR=storage/media

# Path do Socket.IO. Em desenvolvimento, deixe o default /socket.io.
# Atrás do Traefik em subpath (ex.: dev.nvit.com.br/zapbridge), use /zapbridge/socket.io.
SOCKET_IO_PATH=/socket.io

# --- Exemplo de produção no k8s (dev.nvit.com.br/zapbridge) ---
# DATABASE_URL="file:/data/zapbridge.db"
# AUTH_DIR=/data/auth
# MEDIA_DIR=/data/media
# SOCKET_IO_PATH=/zapbridge/socket.io
# CORS_ORIGIN=https://dev.nvit.com.br
