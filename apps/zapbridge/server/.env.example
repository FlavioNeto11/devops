# ZapBridge backend - exemplo de variáveis de ambiente
# Copie para `.env` e ajuste os valores.

PORT=3000

# Segredo do JWT (troque por um valor forte e único)
JWT_SECRET=troque-este-segredo-em-producao
JWT_EXPIRES_IN=30d

# Banco SQLite (Prisma). Para PostgreSQL, troque o provider em prisma/schema.prisma
DATABASE_URL="file:./dev.db"

# Origem permitida no CORS (use * apenas em desenvolvimento)
CORS_ORIGIN=*

# Pastas de armazenamento local
AUTH_DIR=storage/auth
MEDIA_DIR=storage/media

# Path do Socket.IO. Em desenvolvimento, deixe o default /socket.io.
# Atrás do Traefik em subpath (ex.: dev.nvit.com.br/zapbridge), use /zapbridge/socket.io.
SOCKET_IO_PATH=/socket.io

# --- Exemplo de produção no k8s (dev.nvit.com.br/zapbridge) ---
# DATABASE_URL="file:/data/zapbridge.db"
# AUTH_DIR=/data/auth
# MEDIA_DIR=/data/media
# SOCKET_IO_PATH=/zapbridge/socket.io
# CORS_ORIGIN=https://dev.nvit.com.br

# --- IA (opt-in; tudo opcional — sem isto a IA fica desligada e o app sobe normal) ---
# Postgres dedicado (pgvector) p/ threads/memória/embeddings/RAG (NUNCA o SQLite do app):
# AI_DATABASE_URL=postgres://zapbridge:CHANGE_ME@zapbridge-postgres:5432/zapbridge_ai
# Reasoning: Claude (padrão). Use ANTHROPIC_AUTH_TOKEN (assinatura) OU ANTHROPIC_API_KEY.
# AI_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Embeddings SEMPRE OpenAI (Anthropic não expõe /embeddings) — sem isto, RAG/memória degradam:
# OPENAI_API_KEY=sk-...
# AI_EMBEDDING_MODEL=text-embedding-3-small
# AI_GRAPH=on            # liga o assistente com tools (router→ReAct→judge)
# AI_SUGGEST=on          # sugestões de resposta ao receber mensagem
# METRICS_PORT=9464      # /metrics (Prometheus) — porta dedicada, fora do Traefik
# AI_CONTROL_PLANE_URL=  # governança de prompts (opcional)
# AI_CONTROL_PLANE_TOKEN=
