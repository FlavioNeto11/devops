# =============================================================================
# ZapBridge — app web (Vite + React) servido por nginx sob /zapbridge.
# Build do bundle ANTES (na máquina): `npm run build` gera dist/ (base /zapbridge).
# Depois: docker build -f Dockerfile.web -t zapbridge-web:local .
# =============================================================================
FROM nginx:alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf
COPY dist /usr/share/nginx/html
EXPOSE 80
