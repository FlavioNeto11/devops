# Exemplo do Secret de banco do FieldServe (criar FORA do git).
# .tmpl para o Argo NÃO sobrescrever o Secret real (gotcha conhecido do piloto CRM).
#
# Criar com:
#   kubectl create secret generic fieldserve-db -n apps \
#     --from-literal=DATABASE_URL='postgres://fieldserve:<SENHA>@fieldserve-postgres:5432/fieldserve' \
#     --from-literal=POSTGRES_USER='fieldserve' \
#     --from-literal=POSTGRES_PASSWORD='<SENHA>' \
#     --from-literal=POSTGRES_DB='fieldserve'
#
# (opcional, blocos oidc-sessao / ia-grafo)
#   ANTHROPIC_API_KEY / OPENAI_API_KEY  — assistente de IA
#   OIDC_ISSUER / OIDC_CLIENT_ID / OIDC_CLIENT_SECRET / SESSION_SECRET — login corporativo
apiVersion: v1
kind: Secret
metadata: { name: fieldserve-db, namespace: apps }
type: Opaque
stringData:
  DATABASE_URL: "postgres://fieldserve:REPLACE_ME@fieldserve-postgres:5432/fieldserve"
  POSTGRES_USER: "fieldserve"
  POSTGRES_PASSWORD: "REPLACE_ME"
  POSTGRES_DB: "fieldserve"
