PORT=8080
NODE_ENV=development
AUTH_REQUIRED=false
OPENAPI_FILE=./openapi/mtr_automacao_openapi_interna.yaml
DATABASE_URL=postgres://postgres:postgres@localhost:5432/mtr_automation
DATABASE_SSL=false
AUTO_MIGRATE=true
AUTO_SEED=true
STORAGE_DIR=./storage
WORKER_POLL_INTERVAL_MS=2000
WORKER_BATCH_SIZE=10
WORKER_CLAIM_STALE_TIMEOUT_MS=300000
WORKER_CLAIM_HEARTBEAT_MS=15000
JOB_MAX_ATTEMPTS=5
CETESB_GATEWAY_MODE=real
CETESB_BASE_URL=https://mtrr.cetesb.sp.gov.br
CETESB_PORTAL_ORIGIN=https://mtr.cetesb.sp.gov.br
CETESB_PORTAL_REFERER=https://mtr.cetesb.sp.gov.br/
CETESB_USER_AGENT=mtr-automation-node/3.0
CETESB_REQUEST_TIMEOUT_MS=30000
CETESB_TOKEN_HEADER_MODE=both
NODE_OPTIONS=--use-openssl-ca
NODE_EXTRA_CA_CERTS=/opt/certs/cetesb-chain.pem
CETESB_TOKEN_REFRESH_SKEW_SECONDS=120
CETESB_MANIFEST_SEARCH_STATUS_FILTER=8
CETESB_MANIFEST_SEARCH_DAYS_BACK=30
CETESB_DEFAULT_STATE_CODE=26
CETESB_DEFAULT_PACKAGING_TIE_CODIGO=4
CETESB_RESIDUE_SEARCH_SEED_TERMS=Classe A
CETESB_CATALOG_THROTTLE_MS=150

# ─── AI Control Center / Langfuse (observabilidade externa) ───────────────────
# Langfuse é OPCIONAL. Desabilitado (default) NÃO quebra nada; o AI Control Center
# usa traces locais (ai_trace_events) como fallback. NUNCA exponha as chaves ao frontend.
LANGFUSE_ENABLED=false
LANGFUSE_BASE_URL=https://cloud.langfuse.com
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_PROJECT_ID=
LANGFUSE_FLUSH_INTERVAL_MS=5000
LANGFUSE_SYNC_TIMEOUT_MS=8000

# AI Control Center (governança/observabilidade/runtime da IA)
AI_CONTROL_ENABLED=true
AI_CONTROL_READONLY=false
AI_CONTROL_ALLOW_FULL_SMOKE=false
AI_CONTROL_TRACE_RETENTION_DAYS=30
AI_CONTROL_ENABLE_SSE=true
AI_CONTROL_DEBUG=false
