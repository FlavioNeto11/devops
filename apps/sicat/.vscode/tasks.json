{
	"version": "2.0.0",
	"tasks": [
		{
			"label": "install: npm",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "infra: postgres up",
			"type": "shell",
			"command": "docker compose up -d postgres",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "infra: postgres down",
			"type": "shell",
			"command": "docker compose stop postgres",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "infra: postgres reset",
			"dependsOrder": "sequence",
			"dependsOn": [
				"infra: postgres down",
				"infra: postgres up"
			],
			"problemMatcher": []
		},
		{
			"label": "db: migrate",
			"type": "npm",
			"script": "migrate",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": [
				"infra: postgres up"
			],
			"problemMatcher": []
		},
		{
			"label": "db: reset manifests only",
			"type": "shell",
			"command": "node",
			"args": [
				"scripts/reset-manifest-domain.js"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"dependsOn": [
				"infra: postgres up"
			],
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "maintenance"
			}
		},
		{
			"label": "openapi: validate",
			"type": "npm",
			"script": "validate:openapi",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "openapi: generate operations",
			"type": "npm",
			"script": "gen:operations",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "openapi: sync",
			"dependsOrder": "sequence",
			"dependsOn": [
				"openapi: validate",
				"openapi: generate operations"
			],
			"problemMatcher": []
		},
		{
			"label": "api: dev (real)",
			"type": "npm",
			"script": "dev",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Servidor HTTP escutando|listening|ready"
				}
			}
		},
		{
			"label": "api: start (real)",
			"type": "npm",
			"script": "start",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Servidor HTTP escutando|listening|ready"
				}
			},
			"presentation": {
				"panel": "dedicated",
				"group": "api"
			}
		},
		{
			"label": "worker: run (real-dev)",
			"type": "npm",
			"script": "worker",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Worker iniciado|polling|ready"
				}
			}
		},
		{
			"label": "worker: run (real)",
			"type": "npm",
			"script": "worker",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "Worker iniciado|polling|ready"
				}
			},
			"presentation": {
				"panel": "dedicated",
				"group": "worker"
			}
		},
		{
			"label": "stack: prepare local",
			"dependsOrder": "sequence",
			"dependsOn": [
				"install: npm",
				"infra: postgres up",
				"db: migrate",
				"openapi: validate"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: prepare quick",
			"dependsOrder": "sequence",
			"dependsOn": [
				"infra: postgres up",
				"db: migrate",
				"openapi: validate"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: run (real-dev)",
			"dependsOrder": "parallel",
			"dependsOn": [
				"api: dev (real)",
				"worker: run (real-dev)"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: run (real)",
			"dependsOrder": "parallel",
			"dependsOn": [
				"api: start (real)",
				"worker: run (real)"
			],
			"problemMatcher": []
		},
		{
			"label": "frontend: install",
			"type": "shell",
			"command": "npm install",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"problemMatcher": []
		},
		{
			"label": "frontend: test:ui:audit",
			"type": "shell",
			"command": "npx playwright test tests/ui/audit.spec.ts --reporter=list",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "frontend: test:ui:validation",
			"type": "shell",
			"command": "npx playwright test tests/ui/validation-e2e.spec.ts --reporter=list",
			"options": {
				"cwd": "${workspaceFolder}/frontend"
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "frontend: dev (5174)",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"dev",
				"--",
				"--host",
				"127.0.0.1",
				"--port",
				"5174"
			],
			"options": {
				"cwd": "${workspaceFolder}/frontend",
				"env": {
					"VITE_API_BASE_URL": "http://127.0.0.1:8080"
				}
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready in"
				}
			},
			"presentation": {
				"panel": "dedicated",
				"group": "frontend"
			}
		},
		{
			"label": "stack: stop processes",
			"type": "shell",
			"command": "pwsh",
			"args": [
				"-ExecutionPolicy",
				"Bypass",
				"-File",
				"${workspaceFolder}/scripts/restart-stack-vscode.ps1"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"group": "maintenance"
			}
		},
		{
			"label": "stack: run (real + frontend)",
			"dependsOrder": "parallel",
			"dependsOn": [
				"api: start (real)",
				"worker: run (real)",
				"frontend: dev (5174)"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: run (real-dev + frontend)",
			"dependsOrder": "parallel",
			"dependsOn": [
				"api: dev (real)",
				"worker: run (real-dev)",
				"frontend: dev (5174)"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: restart (real + frontend)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: stop processes",
				"stack: run (real + frontend)"
			],
			"problemMatcher": []
		},
		{
			"label": "stack: restart (real-dev + frontend)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: stop processes",
				"stack: run (real-dev + frontend)"
			],
			"problemMatcher": []
		},
		{
			"label": "localhost: up",
			"type": "npm",
			"script": "localhost:up",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"runOptions": {
				"reevaluateOnRerun": true
			},
			"presentation": {
				"reveal": "always",
				"panel": "shared"
			}
		},
		{
			"label": "stack: shutdown",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: stop processes",
				"infra: postgres down"
			],
			"problemMatcher": []
		},
		{
			"label": "validate: agents",
			"type": "npm",
			"script": "validate:agents",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "validate: markdown links",
			"type": "npm",
			"script": "validate:md-links",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "test: api",
			"type": "npm",
			"script": "test:api",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: integration",
			"type": "npm",
			"script": "test:integration",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: worker",
			"type": "npm",
			"script": "test:worker",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: auth",
			"type": "npm",
			"script": "test:auth",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: contract",
			"type": "npm",
			"script": "test:contract",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: source-of-truth",
			"type": "npm",
			"script": "test:source-of-truth",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": "test",
			"problemMatcher": []
		},
		{
			"label": "test: all",
			"type": "npm",
			"script": "test",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"group": {
				"kind": "test",
				"isDefault": true
			},
			"problemMatcher": []
		},
		{
			"label": "workflow: smoke (real)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: prepare local",
				"stack: run (real-dev)",
				"smoke: health",
				"smoke: openapi",
				"smoke: manifest create (real)",
				"smoke: worker once"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: validate local (quick)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"openapi: validate",
				"smoke: health",
				"smoke: openapi",
				"test: auth",
				"test: api"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: validate local (full)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"workflow: validate local (quick)",
				"test: integration",
				"test: worker",
				"test: source-of-truth"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: dev (real-dev)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: prepare quick",
				"stack: restart (real-dev + frontend)"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: dev (real)",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: prepare quick",
				"stack: restart (real + frontend)"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: pre-commit",
			"dependsOrder": "sequence",
			"dependsOn": [
				"workflow: validate workspace",
				"workflow: validate local (quick)",
				"test: contract"
			],
			"problemMatcher": []
		},
		{
			"label": "workflow: validate workspace",
			"dependsOrder": "sequence",
			"dependsOn": [
				"validate: agents",
				"validate: markdown links",
				"openapi: validate"
			],
			"problemMatcher": []
		},
		{
			"label": "handoff front: prepare",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"handoff:front:prepare",
				"--",
				"--dl",
				"${input:handoffFrontDlId}",
				"--title",
				"${input:handoffFrontTitle}",
				"--request",
				"${input:handoffFrontRequest}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "handoff-front"
			}
		},
		{
			"label": "handoff front: watch",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"handoff:front:show",
				"--",
				"--dl",
				"${input:handoffFrontDlId}",
				"--watch",
				"--interval",
				"${input:handoffFrontIntervalMs}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"isBackground": true,
			"problemMatcher": {
				"owner": "custom",
				"pattern": [
					{
						"regexp": ".*"
					}
				],
				"background": {
					"activeOnStart": true,
					"beginsPattern": ".*",
					"endsPattern": "ready=|pending=|in-progress="
				}
			},
			"presentation": {
				"reveal": "always",
				"panel": "dedicated",
				"group": "handoff-front"
			}
		},
		{
			"label": "handoff front: update lane",
			"type": "shell",
			"command": "npm",
			"args": [
				"run",
				"handoff:front:update",
				"--",
				"--dl",
				"${input:handoffFrontDlId}",
				"--agent",
				"${input:handoffFrontAgent}",
				"--status",
				"${input:handoffFrontStatus}",
				"--note",
				"${input:handoffFrontNote}"
			],
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": [],
			"presentation": {
				"reveal": "always",
				"panel": "shared",
				"group": "handoff-front"
			}
		},
		{
			"label": "workflow: handoff front monitor",
			"dependsOrder": "sequence",
			"dependsOn": [
				"handoff front: prepare",
				"handoff front: watch"
			],
			"problemMatcher": []
		},
		{
			"label": "smoke: health",
			"type": "npm",
			"script": "smoke:health",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "smoke: openapi",
			"type": "npm",
			"script": "smoke:openapi",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "smoke: manifest create (real)",
			"type": "npm",
			"script": "smoke:manifest:create",
			"options": {
				"cwd": "${workspaceFolder}",
				"env": {
					"CETESB_GATEWAY_MODE": "real"
				}
			},
			"problemMatcher": []
		},
		{
			"label": "smoke: worker once",
			"type": "npm",
			"script": "worker:once",
			"options": {
				"cwd": "${workspaceFolder}"
			},
			"problemMatcher": []
		},
		{
			"label": "workflow: bootstrap real",
			"dependsOrder": "sequence",
			"dependsOn": [
				"stack: prepare local",
				"stack: run (real-dev)",
				"smoke: health",
				"smoke: openapi"
			],
			"problemMatcher": [],
			"runOptions": {
				"runOn": "default"
			}
		},
		{
			"label": "noop",
			"type": "shell",
			"command": "echo noop"
		}
	],
	"inputs": [
		{
			"id": "handoffFrontDlId",
			"type": "promptString",
			"description": "DL da frente operacional coordenada",
			"default": "DL-087"
		},
		{
			"id": "handoffFrontTitle",
			"type": "promptString",
			"description": "Título da frente operacional coordenada",
			"default": "Frente operacional coordenada"
		},
		{
			"id": "handoffFrontRequest",
			"type": "promptString",
			"description": "Contexto ou request inicial da execução",
			"default": "Escopo, restrições e critérios de pronto da frente coordenada"
		},
		{
			"id": "handoffFrontIntervalMs",
			"type": "promptString",
			"description": "Intervalo do monitor em milissegundos",
			"default": "3000"
		},
		{
			"id": "handoffFrontAgent",
			"type": "pickString",
			"description": "Lane a ser atualizada",
			"options": [
				"integrador-cetesb-mtr",
				"postgres-queue-mtr",
				"dashboard-observability-mtr",
				"jobs-monitoramento-logs-mtr",
				"sessao-conta-mtr",
				"manifestos-operacional-mtr",
				"perfis-acessos-admin-mtr",
				"tester-qa-mtr",
				"documentador-mtr"
			],
			"default": "integrador-cetesb-mtr"
		},
		{
			"id": "handoffFrontStatus",
			"type": "pickString",
			"description": "Novo status da lane",
			"options": [
				"pending",
				"ready",
				"in-progress",
				"blocked",
				"completed",
				"skipped"
			],
			"default": "in-progress"
		},
		{
			"id": "handoffFrontNote",
			"type": "promptString",
			"description": "Nota curta para registrar no board",
			"default": "Atualização realizada via task do VS Code"
		}
	]
}