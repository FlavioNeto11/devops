{
  "name": "mtr-node-backend-postgres-queue",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "description": "Backend Node.js com persistência em Postgres e fila transacional para automação MTR CETESB.",
  "engines": {
    "node": ">=20.11.0"
  },
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "start": "tsx src/server.ts",
    "worker": "tsx src/worker.ts",
    "prepare": "husky",
    "worker:once": "tsx src/worker.ts --once",
    "migrate": "tsx scripts/migrate.js",
    "validate:openapi": "tsx scripts/run-node-clean-env.js scripts/validate-openapi.js scripts/validate-cetesb-source-of-truth.js scripts/validate-markdown-links.js",
    "validate:openapi:clean": "tsx scripts/run-node-clean-env.js scripts/validate-openapi.js scripts/validate-cetesb-source-of-truth.js scripts/validate-markdown-links.js",
    "validate:agents": "tsx scripts/run-node-clean-env.js scripts/validate-agent-architecture.js",
    "validate:ai-chat-catalog": "node scripts/ai-smoke/validate-sicat-chat-catalog.mjs",
    "validate:cetesb-source": "tsx scripts/run-node-clean-env.js scripts/validate-cetesb-source-of-truth.js scripts/validate-har-gateway-structure.js",
    "validate:har-gateway": "tsx scripts/run-node-clean-env.js scripts/validate-har-gateway-structure.js",
    "validate:md-links": "tsx scripts/run-node-clean-env.js scripts/validate-markdown-links.js",
    "scan:secrets": "node scripts/security/scan-secrets.mjs",
    "handoff:front:prepare": "tsx scripts/prepare-operational-front.js",
    "handoff:front:update": "tsx scripts/update-operational-front.js",
    "handoff:front:show": "tsx scripts/show-operational-front.js",
    "gen:operations": "node scripts/generate-operations.js",
    "smoke:health": "node scripts/smoke-health.js",
    "smoke:openapi": "node scripts/smoke-openapi.js",
    "smoke:manifest:create": "node scripts/smoke-manifest-create.js",
    "smoke:job:retry-dlq": "node scripts/smoke-job-retry-dlq.js",
    "smoke:auth": "node scripts/smoke-auth.js",
    "localhost:up": "pwsh -ExecutionPolicy Bypass -File scripts/localhost-up.ps1",
    "test": "tsx --test tests/**/*.test.js",
    "test:api": "tsx --test tests/api/*.test.js",
    "test:integration": "tsx --test tests/integration/*.test.js",
    "test:worker": "tsx --test tests/worker/*.test.js",
    "test:auth": "tsx --test tests/contract/auth-contract.test.js tests/integration/auth-flow.test.js",
    "test:manifest:submit": "tsx --test tests/api/manifest-submit.test.js tests/integration/manifest-submit-service.test.js tests/worker/manifest-submit-handler.test.js",
    "test:contract": "node --test tests/integration/openapi-queue-contract.test.js && npm run validate:openapi",
    "test:source-of-truth": "tsx --test tests/unit/cetesb-source-of-truth.test.js tests/unit/har-gateway-structural-validator.test.js tests/unit/agent-architecture-validation.test.js",
    "lint": "eslint \"src/**/*.ts\" \"scripts/**/*.js\" \"tests/**/*.js\"",
    "lint:fix": "npm run lint -- --fix",
    "check:secrets": "node scripts/check-secrets.js",
    "quality:gate": "node scripts/quality-gate.js",
    "sonar": "sonar-scanner",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "chat:eval:gen": "node scripts/chat-eval/battery.mjs",
    "chat:eval": "node scripts/chat-eval/run.mjs",
    "typecheck:backend": "tsc -p tsconfig.json --noEmit",
    "build:ts": "tsc -p tsconfig.build.json",
    "dev:ts": "tsx watch src/server.ts",
    "start:ts": "tsx src/server.ts",
    "worker:ts": "tsx src/worker.ts",
    "smoke:ai-chat": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.jsonl",
    "smoke:ai-chat:full": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.jsonl --no-fail-fast",
    "smoke:ai-chat:sample": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.sample.jsonl",
    "smoke:ai-chat:sample:full": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.sample.jsonl --no-fail-fast",
    "smoke:ai-chat:category": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.jsonl --category",
    "smoke:ai-chat:category:full": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.jsonl --category --no-fail-fast",
    "smoke:ai-chat:dry-run": "node scripts/ai-smoke/run-sicat-ai-smoke.mjs --catalog docs/ai-chat/intents/sicat-chat-intent-catalog.sample.jsonl --dry-run",
    "rag:ingest": "tsx scripts/rag/ingest-knowledge.ts"
  },
  "dependencies": {
    "@flavioneto11/ai-core": "file:vendor/flavioneto11-ai-core-0.5.1.tgz",
    "@flavioneto11/ai-kit": "file:vendor/flavioneto11-ai-kit-0.1.0.tgz",
    "@flavioneto11/oidc-kit": "file:vendor/flavioneto11-oidc-kit-0.1.0.tgz",
    "@langchain/core": "^1.1.41",
    "@langchain/langgraph": "^1.2.9",
    "@langchain/langgraph-checkpoint-postgres": "^1.0.3",
    "@langchain/openai": "^1.4.4",
    "@types/yazl": "^3.3.1",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "helmet": "^8.1.0",
    "langsmith": "^0.5.22",
    "morgan": "^1.10.0",
    "pdf-parse": "^2.4.5",
    "pg": "^8.14.1",
    "prom-client": "^15.1.3",
    "swagger-ui-express": "^5.0.1",
    "yaml": "^2.8.1",
    "yazl": "^3.3.1"
  },
  "devDependencies": {
    "@apidevtools/swagger-parser": "^12.1.0",
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.3",
    "@types/morgan": "^1.9.9",
    "@types/node": "^24.2.1",
    "@types/pg": "^8.15.5",
    "@types/swagger-ui-express": "^4.1.8",
    "@typescript-eslint/parser": "^8.46.2",
    "eslint": "^9.37.0",
    "husky": "^9.1.7",
    "node-fetch": "^3.3.2",
    "playwright": "^1.59.1",
    "sonar-scanner": "^3.1.0",
    "tsx": "^4.20.3",
    "typescript": "^5.9.2",
    "zod": "^4.1.5"
  }
}
