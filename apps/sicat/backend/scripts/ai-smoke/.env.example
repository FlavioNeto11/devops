# Backend SICAT
SICAT_API_BASE_URL=http://127.0.0.1:8080
SICAT_ACCESS_TOKEN=COLE_UM_ACCESS_TOKEN_VALIDO_AQUI
SICAT_INTEGRATION_ACCOUNT_ID=COLE_INTEGRATION_ACCOUNT_ID
SICAT_SESSION_CONTEXT_ID=COLE_SESSION_CONTEXT_ID
SICAT_ACCOUNT_ID=COLE_ACCOUNT_ID
SICAT_USER_ID=smoke@sicat.local
SICAT_REQUESTED_BY=smoke@sicat.local

# IA do backend: roteamento inteligente de modelos para reduzir custo
# Agent: gpt-5-mini (menos custoso, mantém qualidade em planejamento)
# Synthesis: gpt-4.1-mini (mais econômico para síntese de toolResult)
# Judge: gpt-4.1-mini (padrão para avaliação de qualidade)
# Escalation: gpt-5.1 (apenas para ações sensíveis, diagnósticos complexos)
# Model legado: gpt-5-mini (fallback, preserva compatibilidade)
OPENAI_API_KEY=COLE_SUA_CHAVE_AQUI
OPENAI_AGENT_MODEL=gpt-5-mini
OPENAI_SYNTHESIS_MODEL=gpt-4.1-mini
OPENAI_JUDGE_MODEL=gpt-4.1-mini
OPENAI_ESCALATION_MODEL=gpt-5.1
OPENAI_MODEL=gpt-5-mini

# Segurança do smoke
SICAT_AI_SMOKE_ALLOW_MUTATIONS=false
SICAT_AI_SMOKE_FORCE_SAFE_PROMPT_PREFIX=true

# Execução
SICAT_AI_SMOKE_TIMEOUT_MS=45000
SICAT_AI_SMOKE_CONCURRENCY=1
SICAT_AI_SMOKE_OUTPUT_DIR=artifacts/ai-smoke
