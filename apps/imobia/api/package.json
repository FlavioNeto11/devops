{
  "name": "imobia-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "imobia — API (Fastify + TypeScript via tsx, Prisma + Postgres/pgvector + Redis/BullMQ). Ecossistema imobiliario + fintech orquestrado por multiplas IAs. Mesma imagem serve api (npm start) e worker (npm run worker).",
  "scripts": {
    "start": "prisma migrate deploy && tsx src/server.ts",
    "worker": "tsx src/worker.ts",
    "dev": "tsx watch src/server.ts",
    "prisma:generate": "prisma generate",
    "migrate:dev": "prisma migrate dev",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.32.1",
    "@fastify/cors": "^10.0.1",
    "@fastify/multipart": "^9.0.1",
    "@flavioneto11/ai-core": "file:vendor/flavioneto11-ai-core-0.7.0.tgz",
    "@flavioneto11/ai-kit": "file:vendor/flavioneto11-ai-kit-0.1.0.tgz",
    "@flavioneto11/file-ingest-kit": "file:vendor/flavioneto11-file-ingest-kit-0.1.0.tgz",
    "@flavioneto11/oidc-kit": "file:vendor/flavioneto11-oidc-kit-0.1.0.tgz",
    "@google/generative-ai": "^0.21.0",
    "@prisma/client": "^6.1.0",
    "bullmq": "^5.34.0",
    "fastify": "^5.2.0",
    "ioredis": "^5.4.1",
    "openai": "^4.77.0",
    "prisma": "^6.1.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.6",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
