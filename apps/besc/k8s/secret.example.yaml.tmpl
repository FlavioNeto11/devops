# =============================================================================
# EXEMPLO dos secrets do BESC (Fase 0) — NUNCA aplicar/commitar com valores reais.
#
# Os secrets REAIS entram no git como SealedSecret (kubeseal): sealed-besc-db.yaml
# e sealed-besc-config.yaml, referenciados no kustomization.yaml e gerados pelo
# operador (fluxo em docs/sso-keycloak.md §3). Este arquivo usa a extensao .tmpl
# de proposito: um secret.example.yaml "vivo" dentro do path sincronizado pelo
# Argo CD e APLICADO a cada sync e CLOBBERA o secret real (licao do CRM —
# reqhub-forge-greenfield). Preencha os CHANGE_ME numa copia local temporaria,
# sele com kubeseal e descarte a copia em plaintext.
# =============================================================================
apiVersion: v1
kind: Secret
metadata:
  name: besc-db
  namespace: apps
  labels:
    app.kubernetes.io/part-of: besc
type: Opaque
stringData:
  POSTGRES_DB: besc
  POSTGRES_USER: besc
  POSTGRES_PASSWORD: CHANGE_ME
  # Mesma senha do POSTGRES_PASSWORD acima:
  DATABASE_URL: postgres://besc:CHANGE_ME@besc-postgres:5432/besc
---
apiVersion: v1
kind: Secret
metadata:
  name: besc-config
  namespace: apps
  labels:
    app.kubernetes.io/part-of: besc
type: Opaque
stringData:
  SESSION_SECRET: CHANGE_ME            # >= 32 bytes aleatorios (assina a sessao do oidc-kit)
  BESC_BOOTSTRAP_EMAIL: CHANGE_ME      # conta manager local de bootstrap (fallback ao SSO)
  BESC_BOOTSTRAP_PASSWORD: CHANGE_ME
