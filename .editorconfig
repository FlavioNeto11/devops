# ==========================================================================
# .editorconfig — piso minimo de estilo compartilhado entre apps/escopos
# Lido nativamente por VS Code, JetBrains, vim, etc. (agnostico de toolchain).
# Apps podem sobrescrever com seu proprio .editorconfig/prettier por escopo.
# ==========================================================================
root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

# Scripts nativos do Windows — CRLF (coerente com .gitattributes).
[*.{ps1,psm1,psd1,cmd,bat}]
end_of_line = crlf

# Markdown — preserva espacos finais (quebra de linha por "  ").
[*.md]
trim_trailing_whitespace = false

# Makefile e Go exigem TAB.
[Makefile]
indent_style = tab

[*.go]
indent_style = tab
