{
  "$schema_note": "Fonte ÚNICA dos tokens de design da plataforma NovaIT. O build.mjs gera, por MARCA, os arquivos sincronizados DENTRO de cada app (src/tokens.generated.css + tailwind.tokens.generated.cjs) — porque cada app builda em contexto Docker isolado e não alcança packages/. NÃO edite os arquivos *.generated.* nos apps; edite AQUI e rode `node build.mjs` (CI roda --check). Cores são triplas RGB p/ casar com rgb(var(--x) / <alpha>) no Tailwind.",
  "version": "0.1.0",
  "structural": {
    "font": {
      "display": ["Sora", "system-ui", "sans-serif"],
      "sans": ["Inter", "system-ui", "sans-serif"]
    },
    "boxShadow": {
      "glass": "0 10px 40px -16px rgb(0 0 0 / 0.22)",
      "card": "0 1px 0 0 rgb(255 255 255 / 0.04) inset, 0 16px 44px -26px rgb(0 0 0 / 0.30)",
      "glow": "0 0 0 1px rgb(var(--neon) / 0.20), 0 18px 50px -22px rgb(var(--neon) / 0.32)",
      "soft": "0 12px 34px -18px rgb(0 0 0 / 0.20)"
    },
    "animation": {
      "floaty": "floaty 7s ease-in-out infinite",
      "floaty-slow": "floaty 11s ease-in-out infinite"
    },
    "scrollMarginTop": "92px"
  },
  "brands": {
    "rmambiental": {
      "label": "RM Ambiental — verde/petróleo",
      "secondaryKeys": ["petrol", "petrolLight", "green", "greenMid", "gold"],
      "gradient": "linear-gradient(90deg, rgb(var(--neon)), rgb(var(--greenMid)), rgb(var(--petrolLight)))",
      "btn": { "brightness": "1.07", "shadowAlpha": "0.45", "ghostHoverBorderAlpha": "0.45", "ghostHoverBgAlpha": "0.06" },
      "scrollbarThumbAlpha": "0.2",
      "scrollbarThumbHoverAlpha": "0.35",
      "selectionAlpha": "0.25",
      "glassBgAlpha": "0.6",
      "glassBorderAlpha": "0.08",
      "techGridAlpha": "0.05",
      "light": {
        "bg": "247 249 248", "surface": "255 255 255", "surface2": "237 243 240",
        "fg": "15 27 22", "muted": "86 105 96",
        "neon": "13 148 92", "on-neon": "255 255 255",
        "petrol": "16 110 124", "petrolLight": "21 130 145",
        "green": "22 122 90", "greenMid": "27 138 102", "gold": "176 138 43",
        "ink": "6 16 12"
      },
      "dark": {
        "bg": "10 15 13", "surface": "16 24 21", "surface2": "21 33 29",
        "fg": "232 239 235", "muted": "157 179 170",
        "neon": "52 227 155", "on-neon": "6 16 12",
        "petrol": "13 59 67", "petrolLight": "21 96 110",
        "green": "15 61 46", "greenMid": "27 122 87", "gold": "201 162 75",
        "ink": "6 16 12"
      }
    },
    "sicat": {
      "label": "SICAT — monocromático slate + acento verde-petróleo (marca ADOTADA)",
      "note": "Marca ADOTADA (brownfield): valores TRANSCRITOS da paleta atual do app (zero mudança visual). Renderer próprio em renderers/sicat.mjs (opt-in explícito no build.mjs; NÃO passa por discoverForgeApps). No mapa vuetify, valores '@<nome>' referenciam a cor homônima de css.<modo> (fonte única).",
      "css": {
        "light": {
          "bg": "#f5f7f8", "bg-accent": "#edf1f2",
          "surface": "#ffffff", "surface-raised": "#fafbfc", "surface-subtle": "#f0f3f4",
          "sidebar": "#f8fafa",
          "border": "#e1e7ea", "border-strong": "#c5d0d6",
          "text": "#182226", "text-muted": "#5c6e76",
          "primary": "#0e6e5c", "primary-dark": "#0a5547", "primary-contrast": "#ffffff",
          "error": "#c24444", "success": "#1f7e58", "warning": "#b06a14", "info": "#1f758a",
          "status-neutral-bg": "#eaeff1", "status-neutral-fg": "#45565e",
          "status-running-bg": "#e2f0f2", "status-running-fg": "#15616b",
          "status-success-bg": "#e2f2e9", "status-success-fg": "#1a5e3d",
          "status-error-bg": "#f9e5e5", "status-error-fg": "#963131",
          "status-warning-bg": "#f8eedd", "status-warning-fg": "#8a540f"
        },
        "dark": {
          "bg": "#0c1114", "bg-accent": "#11181c",
          "surface": "#131a1e", "surface-raised": "#192328", "surface-subtle": "#1e2a30",
          "sidebar": "#0a0f12",
          "border": "#263239", "border-strong": "#3b4d56",
          "text": "#e6ecef", "text-muted": "#97a8b0",
          "primary": "#35b493", "primary-dark": "#259478", "primary-contrast": "#08110e",
          "error": "#e07b7b", "success": "#4cc28e", "warning": "#dca557", "info": "#56b8c4",
          "status-neutral-bg": "#222e35", "status-neutral-fg": "#c3d4dc",
          "status-running-bg": "#173e43", "status-running-fg": "#8adde2",
          "status-success-bg": "#1b4231", "status-success-fg": "#9fe5c3",
          "status-error-bg": "#46282c", "status-error-fg": "#f2adb3",
          "status-warning-bg": "#423318", "status-warning-fg": "#f0ce9b"
        }
      },
      "shadows": {
        "light": { "sm": "0 1px 2px rgba(16, 24, 28, 0.06)", "md": "0 4px 16px rgba(16, 24, 28, 0.08)", "lg": "0 12px 32px rgba(16, 24, 28, 0.14)" },
        "dark": { "sm": "0 1px 2px rgba(0, 0, 0, 0.4)", "md": "0 4px 16px rgba(0, 0, 0, 0.45)", "lg": "0 12px 32px rgba(0, 0, 0, 0.55)" }
      },
      "gradients": {
        "light": {
          "primary": "linear-gradient(135deg, var(--color-primary) 0%, var(--color-primary-dark) 100%)",
          "hero": "linear-gradient(180deg, #ffffff 0%, #f5f7f8 100%)"
        },
        "dark": {
          "primary": "linear-gradient(135deg, var(--color-primary-dark) 0%, var(--color-primary) 100%)",
          "hero": "linear-gradient(180deg, #10181c 0%, #0c1114 100%)"
        }
      },
      "vuetify": {
        "light": {
          "primary": "@primary", "secondary": "@status-neutral-fg",
          "success": "@success", "warning": "@warning", "error": "@error", "info": "@info",
          "background": "@bg", "surface": "@surface",
          "surface-bright": "@surface", "surface-light": "@surface-subtle"
        },
        "dark": {
          "primary": "@primary", "secondary": "@text-muted",
          "success": "@success", "warning": "@warning", "error": "@error", "info": "@info",
          "background": "@bg", "surface": "@surface",
          "surface-bright": "@surface-raised", "surface-light": "@surface-subtle"
        }
      }
    },
    "anarabottini": {
      "label": "Ana Rabottini — quente/humanista (só claro)",
      "secondaryKeys": ["terra", "terra-light", "sage", "sage-mid", "gold-neuro"],
      "gradient": "linear-gradient(95deg, rgb(var(--neon)), rgb(var(--terra)))",
