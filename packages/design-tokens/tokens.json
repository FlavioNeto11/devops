        "fg": "30 26 23", "muted": "107 98 88",
        "neon": "138 101 32", "on-neon": "255 255 255",
        "terra": "201 123 90", "terra-light": "216 152 122",
        "sage": "126 139 114", "sage-mid": "143 156 128",
        "gold-neuro": "201 162 39",
        "ink": "30 26 23"
      },
      "dark": null
    }
  }
