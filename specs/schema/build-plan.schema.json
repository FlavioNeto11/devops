{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://nvit.com.br/devops/specs/build-plan.schema.json",
  "title": "Plano de build greenfield — DAG + ADRs + ordem",
  "description": "Projeção navegável da ordem de construção de um produto. Mora em specs/products/<name>/build-plan.json. Gerado na fase de arquitetura (Claude) e aprovado por humano. baseline_hash ancora o plano a uma versão da baseline (detecção de drift). A verdade das dependências são os links[type=depends_on] nos YAMLs; aqui é a projeção.",
  "type": "object",
  "additionalProperties": false,
  "required": ["product", "blueprint", "baseline_hash", "status", "scaffold_req", "waves", "order"],
  "properties": {
    "product": { "type": "string", "pattern": "^[a-z][a-z0-9-]{1,30}$" },
    "blueprint": { "type": "string", "pattern": "^[a-z0-9-]+$" },
    "blueprint_version": { "type": "string" },
    "baseline_hash": { "type": "string", "pattern": "^[a-f0-9]{64}$" },
    "generated_by": { "type": "string", "description": "Prompt/versão que gerou o plano (rastreabilidade)." },
    "status": { "enum": ["proposed", "approved"] },
    "scaffold_req": { "type": "string", "pattern": "^REQ-[A-Z0-9]+-[0-9]{3,4}$", "description": "O requisito de fundação (applies_to: product-foundation) que cria apps/<name>/." },
    "adrs": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["ref", "title", "status"],
        "properties": {
          "ref": { "type": "string" },
          "title": { "type": "string" },
          "status": { "enum": ["proposed", "accepted"] },
          "rationale": { "type": "string" }
        }
      }
    },
    "modules": {
      "type": "array",
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "requirement_ids"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "title": { "type": "string" },
          "requirement_ids": { "type": "array", "items": { "type": "string", "pattern": "^REQ-[A-Z0-9]+-(NFR-)?[0-9]{3,4}$" } },
          "depends_on": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "waves": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "required": ["id", "work_orders"],
        "properties": {
          "id": { "type": "string", "pattern": "^[a-z0-9-]+$" },
          "gate": { "enum": ["auto", "human"], "default": "auto" },
          "work_orders": { "type": "array", "items": { "type": "string", "pattern": "^REQ-[A-Z0-9]+-(NFR-)?[0-9]{3,4}$" } },
          "depends_on": { "type": "array", "items": { "type": "string" } }
        }
      }
    },
    "order": { "type": "array", "items": { "type": "string", "pattern": "^REQ-[A-Z0-9]+-(NFR-)?[0-9]{3,4}$" }, "description": "Ordem topológica achatada (UI/orquestrador percorrem isto)." }
  }
}
